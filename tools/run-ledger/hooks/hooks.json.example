{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "/home/dn/.drivenets/cheetah/AI/v2/private/tools/run-ledger/hooks/run-ledger.sh sessionStart" }
    ],
    "subagentStart": [
      { "command": "/home/dn/.drivenets/cheetah/AI/v2/private/tools/run-ledger/hooks/run-ledger.sh subagentStart" }
    ],
    "subagentStop": [
      { "command": "/home/dn/.drivenets/cheetah/AI/v2/private/tools/run-ledger/hooks/run-ledger.sh subagentStop" }
    ],
    "postToolUse": [
      { "command": "/home/dn/.drivenets/cheetah/AI/v2/private/tools/run-ledger/hooks/run-ledger.sh postToolUse", "matcher": "Task|Shell|MCP" }
    ],
    "postToolUseFailure": [
      { "command": "/home/dn/.drivenets/cheetah/AI/v2/private/tools/run-ledger/hooks/run-ledger.sh postToolUseFailure" }
    ],
    "preCompact": [
      { "command": "/home/dn/.drivenets/cheetah/AI/v2/private/tools/run-ledger/hooks/run-ledger.sh preCompact" }
    ],
    "stop": [
      { "command": "/home/dn/.drivenets/cheetah/AI/v2/private/tools/run-ledger/hooks/run-ledger.sh stop" }
    ]
  }
}
